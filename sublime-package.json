													"default": "space",
													"description": "Kind of whitespace to use for indentation"
												},
												"indent_size": {
													"type": "integer",
													"default": 4,
													"description": "Number of spaces to indent by"
												},
												"tab_width": {
													"type": "integer",
													"default": 4,
													"description": "Visual width tabs"
												}
											}
										},
										"csharp|code_style.formatting.new_line": {
											"type": "object",
											"description": "Newline settings",
											"properties": {
												"end_of_line": {
													"type": "string",
													"enum": ["...", "default", "platform-specific"],
													"default": "...",
													"description": "Newline type to insert"
												},
												"insert_final_newline": {
													"type": "boolean",
													"default": false,
													"description": "Ensure newline at end of file"
												}
