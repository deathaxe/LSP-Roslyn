{
	"contributions": {
		"settings": [
			{
				"file_patterns": [
					"/LSP-Roslyn.sublime-settings"
				],
				"schema": {
					"$id": "sublime://settings/LSP-Roslyn",
					"allOf": [
						{
							"$ref": "sublime://settings/LSP-plugin-base"
						},
						{
							"$ref": "sublime://settings/LSP-Roslyn#/definitions/PluginConfig"
						}
					],
					"definitions": {
						"PluginConfig": {
							"properties": {
								"install_command": {
									"type": "array",
									"default": ["dotnet", "tool", "install", "roslyn-language-server", "--prerelease", "--tool-path", "${server_path}"],
									"description": "Background analysis settings for diagnostics"
								},
								"settings": {
									"type": "object",
									"additionalProperties": false,
									"properties": {
										"code_style.formatting.new_line": {
											"type": "object",
											"description": "Newline settings",
											"properties": {
												"insert_final_newline": {
													"type": "boolean",
													"default": false,
													"description": "Ensure newline at end of file"
												}
											}
										},
										"navigation": {
											"type": "object",
											"additionalProperties": false,
											"description": "Navigation settings",
											"properties": {
												"dotnet_navigate_to_decompiled_sources": {
													"type": "boolean",
													"default": true
												},
												"dotnet_navigate_to_source_link_and_embedded_sources": {
													"type": "boolean",
													"default": true
												}
											}
										},
										"projects": {
											"type": "object",
											"additionalProperties": false,
											"description": "Project settings",
											"properties": {
												"dotnet_binary_log_path": {
													"type": ["string", "null"],
													"default": null
												},
												"dotnet_enable_automatic_restore": {
													"type": "boolean",
													"default": true
												},
												"dotnet_enable_file_based_programs": {
													"type": "boolean",
													"default": true
												},
												"dotnet_enable_file_based_programs_when_ambiguous": {
													"type": "boolean",
													"default": true
												}
											}
										},

										// CSharp

										"csharp|auto_insert": {
											"type": "object",
											"description": "Automatic insert features",
											"properties": {
												"dotnet_enable_auto_insert": {
													"type": "boolean",
													"default": true,
													"description": "Enable automatic insertion of required 'using' statements."
												}
											}
										},
										"csharp|background_analysis": {
											"type": "object",
											"description": "Background analysis settings for diagnostics",
											"properties": {
												"dotnet_analyzer_diagnostics_scope": {
													"type": "string",
													"enum": ["default", "openFiles", "fullSolution", "none"],
													"default": "default",
													"description": "Scope of the background analysis for .NET analyzer diagnostics"
												},
												"dotnet_compiler_diagnostics_scope": {
													"type": "string",
													"enum": ["openFiles", "fullSolution", "none"],
													"default": "openFiles",
													"description": "Scope of the background analysis for .NET compiler diagnostics"
												}
											}
										},
										"csharp|code_lens": {
											"type": "object",
											"description": "Code lens settings",
											"properties": {
												"dotnet_enable_references_code_lens": {
													"type": "boolean",
													"default": true,
													"description": "Enable code lens references"
												},
												"dotnet_enable_tests_code_lens": {
													"type": "boolean",
													"default": true,
													"description": "Enable tests code lens"
